APP_NAME=ResumeHaven
APP_ENV=testing
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=:memory:

CACHE_STORE=array
SESSION_DRIVER=array
QUEUE_CONNECTION=sync
MAIL_MAILER=array

# Use mock provider in CI to avoid external API dependencies.
AI_PROVIDER=mock

# Placeholder for parity with local/prod configs; intentionally empty in CI.
GEMINI_API_KEY=

